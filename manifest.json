{
   "action": {
      "default_icon": {
         "128": "icon/icon128.png",
         "16": "icon/icon16.png",
         "48": "icon/icon48.png"
      },
      "default_title": "ImgPrompt"
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "capture_screenshot": {
         "description": "Capture screenshot and extract prompt",
         "suggested_key": {
            "default": "Alt+S",
            "mac": "Alt+S"
         }
      }
   },
   "content_scripts": [ {
      "js": [ "config.js", "content.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_idle"
   } ],
   "default_locale": "en",
   "description": "__MSG_extDescription__",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icon/icon128.png",
      "16": "icon/icon16.png",
      "48": "icon/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_extName__",
   "permissions": [ "contextMenus", "storage", "sidePanel", "activeTab" ],
   "side_panel": {
      "default_path": "options.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.0"
}
